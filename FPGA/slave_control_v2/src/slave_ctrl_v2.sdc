#=============================================================================
# slave_ctrl_v2 - 分控板V2.0 时序约束文件
#=============================================================================
# 时钟: 50MHz 外部晶振, 周期 20ns
#=============================================================================
create_clock -name clk -period 20.000 -waveform {0.000 10.000} [get_ports {clk}]

#=============================================================================
# mac_32 内部采样时钟 (50MHz/10000 ≈ 5kHz, DDR等效10kHz)
# 用于故障检测毛刺滤波，慢速信号无需严格时序
#=============================================================================
create_generated_clock -name clk_sample -source [get_ports {clk}] -divide_by 10000 [get_nets {u_slave/u_fault_det/gen_channels[0].u_filter/clk_sample}]

#=============================================================================
# 滤波输出作为 err_dff 时钟 — 数据派生信号，设 false path
#=============================================================================
set_false_path -through [get_nets {u_slave/u_fault_det/filtered_2[*]}]

#=============================================================================
# tx_load — com_tx 加载控制信号，非时钟
#=============================================================================
set_false_path -through [get_nets {u_slave/tx_load}]
