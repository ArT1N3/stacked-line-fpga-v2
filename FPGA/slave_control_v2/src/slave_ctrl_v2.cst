//File Title: Physical Constraints file
//GOWIN Version: V2.0
//Part Number: GW1N-UV9QN88C6/I5
//Device: GW1N-9C
//Description: V2.0 分控板 — 引脚按功能分组，同类接口连续排列
//             PCB布局：底边(时钟+继电器+短路) | 右边(光纤) | 左边(地址+LED+复位)

//==================================================================
// 系统时钟 (pin 11 = GCLK, 底部)
//==================================================================
IO_LOC "clk" 11;
IO_PORT "clk" IO_TYPE=LVCMOS33 PULL_MODE=UP BANK_VCCIO=3.3;

//==================================================================
// 继电器控制输出 (4路, pins 13-16 底部连续) → 继电器驱动电路
//==================================================================
IO_LOC "relay_out[0]" 13;
IO_PORT "relay_out[0]" IO_TYPE=LVCMOS33 PULL_MODE=UP DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "relay_out[1]" 14;
IO_PORT "relay_out[1]" IO_TYPE=LVCMOS33 PULL_MODE=UP DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "relay_out[2]" 15;
IO_PORT "relay_out[2]" IO_TYPE=LVCMOS33 PULL_MODE=UP DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "relay_out[3]" 16;
IO_PORT "relay_out[3]" IO_TYPE=LVCMOS33 PULL_MODE=UP DRIVE=8 BANK_VCCIO=3.3;

//==================================================================
// 短路检测输入 (4路, pins 17-20 底部连续) → 比较器电路
//==================================================================
IO_LOC "short_in[0]" 17;
IO_PORT "short_in[0]" IO_TYPE=LVCMOS33 PULL_MODE=UP BANK_VCCIO=3.3;
IO_LOC "short_in[1]" 18;
IO_PORT "short_in[1]" IO_TYPE=LVCMOS33 PULL_MODE=UP BANK_VCCIO=3.3;
IO_LOC "short_in[2]" 19;
IO_PORT "short_in[2]" IO_TYPE=LVCMOS33 PULL_MODE=UP BANK_VCCIO=3.3;
IO_LOC "short_in[3]" 20;
IO_PORT "short_in[3]" IO_TYPE=LVCMOS33 PULL_MODE=UP BANK_VCCIO=3.3;

//==================================================================
// 光纤收发 (2路, pins 25-26 右边相邻) → 光模块
//==================================================================
IO_LOC "TXD" 25;
IO_PORT "TXD" IO_TYPE=LVCMOS33 PULL_MODE=UP DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "RXD" 26;
IO_PORT "RXD" IO_TYPE=LVCMOS33 PULL_MODE=UP BANK_VCCIO=3.3;

//==================================================================
// 故障指示灯 (4路, pins 68-71 左边连续) → LED排
//==================================================================
IO_LOC "fault_led[0]" 68;
IO_PORT "fault_led[0]" IO_TYPE=LVCMOS33 PULL_MODE=UP DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "fault_led[1]" 69;
IO_PORT "fault_led[1]" IO_TYPE=LVCMOS33 PULL_MODE=UP DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "fault_led[2]" 70;
IO_PORT "fault_led[2]" IO_TYPE=LVCMOS33 PULL_MODE=UP DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "fault_led[3]" 71;
IO_PORT "fault_led[3]" IO_TYPE=LVCMOS33 PULL_MODE=UP DRIVE=8 BANK_VCCIO=3.3;

//==================================================================
// 状态指示灯 (1路, pin 72 左边, 紧接故障灯)
//==================================================================
IO_LOC "status_led" 72;
IO_PORT "status_led" IO_TYPE=LVCMOS33 PULL_MODE=UP DRIVE=8 BANK_VCCIO=3.3;

//==================================================================
// 8位地址拨码 (pins 79-86 左边连续) → DIP开关
//==================================================================
IO_LOC "address[0]" 79;
IO_PORT "address[0]" IO_TYPE=LVCMOS33 PULL_MODE=UP BANK_VCCIO=3.3;
IO_LOC "address[1]" 80;
IO_PORT "address[1]" IO_TYPE=LVCMOS33 PULL_MODE=UP BANK_VCCIO=3.3;
IO_LOC "address[2]" 81;
IO_PORT "address[2]" IO_TYPE=LVCMOS33 PULL_MODE=UP BANK_VCCIO=3.3;
IO_LOC "address[3]" 83;
IO_PORT "address[3]" IO_TYPE=LVCMOS33 PULL_MODE=UP BANK_VCCIO=3.3;
IO_LOC "address[4]" 84;
IO_PORT "address[4]" IO_TYPE=LVCMOS33 PULL_MODE=UP BANK_VCCIO=3.3;
IO_LOC "address[5]" 85;
IO_PORT "address[5]" IO_TYPE=LVCMOS33 PULL_MODE=UP BANK_VCCIO=3.3;
IO_LOC "address[6]" 86;
IO_PORT "address[6]" IO_TYPE=LVCMOS33 PULL_MODE=UP BANK_VCCIO=3.3;
IO_LOC "address[7]" 87;
IO_PORT "address[7]" IO_TYPE=LVCMOS33 PULL_MODE=UP BANK_VCCIO=3.3;

//==================================================================
// 复位 (pin 73 左边, LED区域旁)
//==================================================================
IO_LOC "rst" 73;
IO_PORT "rst" IO_TYPE=LVCMOS33 PULL_MODE=UP BANK_VCCIO=3.3;
